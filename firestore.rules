rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 1. GLOBAL SAFETY NET ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 2. GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'antonchakma6@gmail.com') ||
        (request.auth.token.email == 'admin@afd.house') ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)))
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- 3. ENTITY VALIDATIONS ---

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'category', 'stock', 'sizes', 'colors', 'images']) &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             data.category is string &&
             data.sizes is list &&
             data.colors is list &&
             data.images is list;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'customerInfo', 'items', 'total', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.items is list && data.items.size() > 0;
    }

    // --- 4. MATCH BLOCKS ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                      (incoming().role == 'user' || (request.auth.token.email == 'antonchakma6@gmail.com' && isVerified()));
      
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        // Action: Update Profile
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'role']) && 
         (incoming().role == existing().role || isAdmin())) ||
        // Action: Admin Overwrite
        isAdmin()
      );
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled']
      );
    }
  }
}
